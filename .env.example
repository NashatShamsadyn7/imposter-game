# Supabase — بۆ چوونەژوورەوەی Google و هاوکاتکردنی کلاود (ئارەزوومەندانە)
# ئەگەر بەتاڵیان بهێڵیتەوە، ئەپەکە بە شێوەی ئۆفلاین کاردەکات.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push — کلیلی گشتیی VAPID (بۆ ئاگادارکردنەوە کاتێک ئەپ داخراوە)
# بە web-push generate-vapid-keys دروستی بکە. بڕوانە WEB_PUSH_SETUP.md
VITE_VAPID_PUBLIC_KEY=
